*32 (CommentText
uid 4788,0
shape (Rectangle
uid 4789,0
layer 0
va (VaSet
vasetType 1
fg "65280,65280,46080"
lineColor "0,0,32768"
)
xt "203000,49000,238000,58000"
)
oxt "0,0,15000,5000"
text (MLText
uid 4790,0
va (VaSet
fg "0,0,32768"
)
xt "203200,49200,237500,57200"
st "
TxDataAddr <= \"11111\" & RtLen_Mode when RtSubAddr = \"00000\" or RtSubAddr = \"11111\" else
                             RtSubAddr & std_logic_vector(to_unsigned(WordCount,5));
RxDataAddr <= \"11111\" & RtLen_Mode when RtSubAddr = \"00000\" or RtSubAddr = \"11111\" else
                      RtSubAddr & std_logic_vector(to_unsigned(WordCount,5));



or(RtAddr = \"11111\" and RtSubAddr /= \"00000\" and RtSubAddr /= \"11111\")
"
tm "CommentText"
wrapOption 3
visibleHeight 9000
visibleWidth 35000
)
)
