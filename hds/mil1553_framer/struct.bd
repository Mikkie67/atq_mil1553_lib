*483 (HdlText
uid 3583,0
optionalChildren [
*484 (EmbeddedText
uid 3589,0
commentText (CommentText
uid 3590,0
ps "CenterOffsetStrategy"
shape (Rectangle
uid 3591,0
va (VaSet
vasetType 1
fg "65535,65535,65535"
lineColor "0,0,32768"
lineWidth 2
)
xt "68000,8000,123000,139000"
)
text (MLText
uid 3592,0
va (VaSet
font "arial,8,0"
)
xt "68200,8200,120000,137200"
st "
-- ebPortSelection 1                                        
   -- Assign top block inputs to RT component inputs (suffix 1)
   BIT_word1               <= BIT_word;
   BrdcstRxed1             <= BrdcstRxed;
   BroadcastEnable1        <= BroadcastEnable;
   Busy1                   <= Busy;
   Clear_InitiateBIT_Rxed1 <= Clear_InitiateBIT_Rxed;
   Clear_Sync_Rxed1        <= Clear_Sync_Rxed;
   Clk1                    <= Clk;
   CmdEdge1                <= CmdEdge;
   CmdProcLen1             <= CmdProcLen;
   CmdProcStart1           <= CmdProcStart;
   Cmd_nDataIn1            <= Cmd_nDataIn;
   DBC_Enable1             <= DBC_Enable;
   DataWrapSubAddr1        <= DataWrapSubAddr;
   DecoderErr1             <= DecoderErr;
   Done1                   <= Done;
   EnableHwDataWrap1       <= EnableHwDataWrap;
   Err_inj1                <= Err_inj;
   Instrumentation1        <= Instrumentation;
   IsRT1                   <= IsRT;
   LegalModeBrdcst1        <= LegalModeBrdcst;
   LegalModeRx1            <= LegalModeRx;
   LegalModeTx1            <= LegalModeTx;
   LegalSubAddr1           <= LegalSubAddr;
   MyRtAddr1               <= MyRtAddr;
   NegEdge1                <= NegEdge;
   NewWord1                <= NewWord;
   OutWord1                <= OutWord;
   PosEdge1                <= PosEdge;
   SendMessage1            <= SendMessage;
   ServiceReqVector1       <= ServiceReqVector;
   ServiceRequest1         <= ServiceRequest;
   SubsystemFlag1          <= SubsystemFlag;
   TerminalFlagIn1         <= TerminalFlagIn;
   TxDataIn1               <= TxDataIn;
   nReset1                 <= nReset;
   tmr_1us1                <= tmr_1us;
   tmr_25us1               <= tmr_25us;
   tmr_GAP1                <= tmr_GAP;
   tmr_NRP1                <= tmr_NRP;
   tmr_REP1                <= tmr_REP;
   tmr_SAF1                <= tmr_SAF;

   -- Assign top block inputs to BC component inputs (suffix 2)
   BIT_word2               <= BIT_word;
   BrdcstRxed2             <= BrdcstRxed;
   BroadcastEnable2        <= BroadcastEnable;
   Busy2                   <= Busy;
   Clear_InitiateBIT_Rxed2 <= Clear_InitiateBIT_Rxed;
   Clear_Sync_Rxed2        <= Clear_Sync_Rxed;
   Clk2                    <= Clk;
   CmdEdge2                <= CmdEdge;
   CmdProcLen2             <= CmdProcLen;
   CmdProcStart2           <= CmdProcStart;
   Cmd_nDataIn2            <= Cmd_nDataIn;
   DBC_Enable2             <= DBC_Enable;
   DataWrapSubAddr2        <= DataWrapSubAddr;
   DecoderErr2             <= DecoderErr;
   Done2                   <= Done;
   EnableHwDataWrap2       <= EnableHwDataWrap;
   Err_inj2                <= Err_inj;
   Instrumentation2        <= Instrumentation;
   IsRT2                   <= IsRT;
   LegalModeBrdcst2        <= LegalModeBrdcst;
   LegalModeRx2            <= LegalModeRx;
   LegalModeTx2            <= LegalModeTx;
   LegalSubAddr2           <= LegalSubAddr;
   MyRtAddr2               <= MyRtAddr;
   NegEdge2                <= NegEdge;
   NewWord2                <= NewWord;
   OutWord2                <= OutWord;
   PosEdge2                <= PosEdge;
   SendMessage2            <= SendMessage;
   ServiceReqVector2       <= ServiceReqVector;
   ServiceRequest2         <= ServiceRequest;
   SubsystemFlag2          <= SubsystemFlag;
   TerminalFlagIn2         <= TerminalFlagIn;
   TxDataIn2               <= TxDataIn;
   nReset2                 <= nReset;
   tmr_1us2                <= tmr_1us;
   tmr_25us2               <= tmr_25us;
   tmr_GAP2                <= tmr_GAP;
   tmr_NRP2                <= tmr_NRP;
   tmr_REP2                <= tmr_REP;
   tmr_SAF2                <= tmr_SAF;

   -- Output port selection based on CoreMode generic
   -- If RT_MODE: use RT framer outputs (suffix 1)
   -- If BC_MODE: use BC framer outputs (suffix 2)
   -- If BCRT_MODE: use IsRT signal to select RT (suffix 1) or BC (suffix 2)
   BlankDecoder     <= BlankDecoder1     when (CoreMode = RT_MODE) or (CoreMode = BCRT_MODE and IsRT = '1') else BlankDecoder2;
   BusActive        <= BusActive1        when (CoreMode = RT_MODE) or (CoreMode = BCRT_MODE and IsRT = '1') else BusActive2;
   BusReset_Rxed    <= BusReset_Rxed1    when (CoreMode = RT_MODE) or (CoreMode = BCRT_MODE and IsRT = '1') else BusReset_Rxed2;
   CmdRxed          <= CmdRxed1          when (CoreMode = RT_MODE) or (CoreMode = BCRT_MODE and IsRT = '1') else CmdRxed2;
   Cmd_nData        <= Cmd_nData1        when (CoreMode = RT_MODE) or (CoreMode = BCRT_MODE and IsRT = '1') else Cmd_nData2;
