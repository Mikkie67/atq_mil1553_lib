TxDataAddr <=   Addr(9 downto 0) when Addr(11 downto 10) = \"01\" and Rd = '1' else
                             TxDataAddr1 when ActiveBus = '0' else 
                             TxDataAddr2;

RxDataWr <= Wr when Addr(11 downto 10) = \"10\" and Wr = '1' else
                         RxDataWr1 when ActiveBus = '0' else 
                         RxDataWr2;
RxDataAddr <= Addr(9 downto 0) when Addr(11 downto 10) = \"10\" and Wr = '1' else
                            RxDataAddr1 when ActiveBus ='0' else 
                            RxDataAddr2;

"
tm "CommentText"
wrapOption 3
visibleHeight 20000
visibleWidth 35000
)
)
