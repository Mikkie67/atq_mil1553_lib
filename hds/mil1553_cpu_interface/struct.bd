*137 (HdlText
uid 1344,0
optionalChildren [
*138 (EmbeddedText
uid 1350,0
commentText (CommentText
uid 1351,0
ps "CenterOffsetStrategy"
shape (Rectangle
uid 1352,0
va (VaSet
vasetType 1
fg "65535,65535,65535"
lineColor "0,0,32768"
lineWidth 2
)
xt "80000,117000,123000,162000"
)
oxt "0,0,18000,5000"
text (MLText
uid 1353,0
va (VaSet
)
xt "80200,117200,117300,162200"
st "
-- eRAM_IF 1  
tx_control_RT2RT <= tx_control_RT2RT1 when ActiveBus = '0' else tx_control_RT2RT2;            
TxDataIn1 <= tx_q when DataWrapActive1 = '0' else rx_q;
TxDataIn2 <= tx_q when DataWrapActive2 = '0' else rx_q;
-- NOTE: Reading from the TxRAM and Writing to the RxRAM from the CPU may cause data failures
-- and should ONLY be used for debugging purposes.
TxDataAddr <=   cpu_tx_wraddress when DebugRAM = '1' else
                           TxDataAddr1 when ActiveBus = '0' else 
                           TxDataAddr2 when ActiveBus = '1' else 
                           (others => '0');
RamDataValid <= DelayedRdEn when Addr(11 downto 10) = \"01\" or Addr(11 downto 10) = \"10\" else
                           RegDataValid;
DataValid <= RamDataValid;
tx_data <= tx_control_RT2RT1 & DataIn when ActiveBus = '0' and Addr(11 downto 10) = \"01\" else 
                  tx_control_RT2RT2 & DataIn when ActiveBus = '1' and Addr(11 downto 10) = \"01\" else
                  (others => '0');
rx_rdaddress <= cpu_rx_rdaddress(9 downto 0) when DebugRAM = '1' else
                      cpu_rx_rdaddress(9 downto 0) when DataWrapActive1 = '0' and DataWrapActive2 = '0' else
                      TxDataAddr1 when DataWrapActive1  = '1' and ActiveBus = '0' and DebugRAM = '0' else
                      TxDataAddr2 when DataWrapActive2  = '1' and ActiveBus = '1' and DebugRAM = '0' else
                      (others => '0');
cpu_rx_data <= rx_q(15 downto 0);
rx_data <= '0' & DataIn when DebugRAM = '1' else
                  '0' & RxDataOut1 when ActiveBus = '0' else 
                  '0' & RxDataOut2 when ActiveBus = '1' else
                  '0' & X\"A5A5\";
RxDataWr <=    cpu_rx_wren when DebugRAM = '1' else
                        RxDataWr1 when ActiveBus = '0' else 
                        RxDataWr2 when ActiveBus = '1' else
                        '0';
RxDataAddr <=    cpu_rx_rdaddress when DebugRAM = '1' else
                          RxDataAddr1 when ActiveBus ='0' else 
                          RxDataAddr2 when ActiveBus = '1' else
                           (others => '0');
-- Address mapping to RAM
cpu_tx_wraddress  <= Addr(9 downto 0) when Addr(11 downto 10) = \"01\" else (others => '0');
cpu_rx_rdaddress <= Addr(9 downto 0) when Addr(11 downto 10) = \"10\" else (others => '0');
cpu_tx_wren <=Wr when Addr(11 downto 10) = \"01\" else '0';
cpu_rx_wren <=Wr when Addr(11 downto 10) = \"10\" else '0';

DataOut <=  cpu_reg_dataout when Addr(11 downto 10) = \"00\" else
                   tx_q(15 downto 0) when Addr(11 downto 10) = \"01\" else
                   rx_q(15 downto 0) when Addr(11 downto 10) = \"10\" else
                   X\"DEAD\";


"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 45000
visibleWidth 43000
)
)
)
]
shape (Rectangle
uid 1345,0
va (VaSet
