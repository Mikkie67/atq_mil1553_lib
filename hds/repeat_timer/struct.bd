text (MLText
uid 436,0
va (VaSet
font "arial,8,0"
)
xt "58200,41200,88800,53200"
st "
-- ebPortSelection 1     
   -- Output port selection based on CoreMode generic
   -- If RT_MODE: set outputs constant low
   -- If BC_MODE: use timer outputs
   -- If BCRT_MODE: use IsRT signal low, use timer outputs otherwise set outputs low
   clockout <= '0' when (CoreMode = RT_MODE)  else clockout1;
   timeout <= '0' when (CoreMode = RT_MODE) else timeout1;
   pulse <= '0' when (CoreMode = RT_MODE) else pulse1;
   timer1_clockout <= '0' when (CoreMode = RT_MODE) else timer1_clockout1;
   timer1_timeout <= '0' when (CoreMode = RT_MODE) else timer1_timeout1;
   timer1_pulse <= '0' when (CoreMode = RT_MODE) else timer1_pulse1;
                                   
"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 14000
visibleWidth 49000
)
)
)
]
