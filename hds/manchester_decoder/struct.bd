text (MLText
uid 1424,0
va (VaSet
)
xt "35200,58200,56200,82200"
st "
-- ebEdgeDetect 2     
process(nReset,Clk)
begin
if (nReset = '0') then
  PosEdge <= '0';
  NegEdge <= '0';
  RegN <= \"11\";
  RegP <= \"00\";
elsif (clk'event and clk='1') then
  RegN <= RegN(0) & nSyncOutP;--used to be SyncOutN
  RegP <= RegP(0) & SyncOutP;
  NegEdge <= '0';
  PosEdge <= '0';
  if (RegP = \"01\" and RegN(0) = '0') then
    PosEdge <= '1';
  elsif (RegN = \"01\" and RegP(0) = '0') then
    NegEdge <= '1';
 -- elsif (RegP = \"01\" and RegN(1) = '1') then
--    PosEdge <= '1';
 -- elsif (RegP = \"10\" and RegN(1) = '1') then
 --   NegEdge <= '1';
  end if;
end if;
end process;                                   
"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 25000
visibleWidth 23000
)
)
)
]
