*225 (MLText
uid 8,0
va (VaSet
font "Courier New,8,0"
)
xt "17000,40000,90000,108000"
st "-- Status bits generated in FSM
signal MessageError : std_logic;
signal sWaitforStatusActive : std_logic;
---------------------------------
signal TxStatus_Rxed : std_logic;
signal TxLastCommand : std_logic;
signal InhibitTFlag_Rxed : std_logic;
signal ClrInhibitTFlag_Rxed : std_logic;
signal ResetRt_Rxed : std_logic;
signal Broadcast : std_logic;
signal WordCount : integer range 0 to 34;
signal CmdCount : integer range 0 to 32;
signal DelayCount : integer;
signal Len : integer range 0 to 33;
signal LegalModeRxed : std_logic;
signal LegalSubAddrRxed : std_logic;
signal PrevStatus : std_logic_vector(15 downto 0);
signal PrevCmdWord : std_logic_vector(15 downto 0);
signal CmdWord : std_logic_vector(15 downto 0);
signal RtAddr : std_logic_vector(4 downto 0);
signal RtSubAddr : std_logic_vector(4 downto 0);
signal RamWaitStates : integer range 0 to 3;
signal RtLen_Mode : std_logic_vector(4 downto 0);
signal Tx_nRx : std_logic;
signal RT2RT : std_logic;
signal RT2RT_Busy : std_logic;
signal RT2RT_RxRtAddr : std_logic_vector(4 downto 0);
signal Status : std_logic_vector(15 downto 0);
signal RT2RT_Flag : std_logic;
function CheckLegalMode(RtLen_Mode : std_logic_vector(4 downto 0); LegalMode :  std_logic_vector(31 downto 0)) return std_logic is
variable Count : integer range 0 to 31;
begin
  Count := to_integer(unsigned(RtLen_Mode));
  return LegalMode(Count);
end function;

function CheckLegalSubaddr (RtSubAddr : std_logic_vector(4 downto 0); LegalSubAddr :  std_logic_vector(31 downto 0)) return std_logic is
variable Count : integer range 0 to 31;
begin
  if (RtSubAddr /= \"00000\" and RtSubAddr /= \"11111\")  then 
    Count := to_integer(unsigned(RtSubAddr));
    return LegalSubAddr(Count);
  else
    return '0';
  End if;
end function;
function BcLegalMode(RtSubAddr: std_logic_vector(4 downto 0); RtLenMode : std_logic_vector(4 downto 0);Tx_nRx : std_logic) return std_logic is
begin
if (RtSubAddr = \"00000\" or RtSubAddr = \"11111\") then 
if (RtLenMode(4) = '0') then
  if (Tx_nRx = '0') then
    return '0';
  else
    case RtLenMode(3 downto 0) is
      when X\"9\" => return '0';
      when X\"A\" => return '0';
      when X\"B\" => return '0';
      when X\"C\" => return '0';
      when X\"D\" => return '0';
      when X\"E\" => return '0';
      when X\"F\" => return '0';
      when others => return '1';
    end case;
  end if;
else
  if (Tx_nRx = '0') then
    case RtLenMode(3 downto 0) is
      when X\"1\" => return '1';
      when X\"4\" => return '1';
      when X\"5\" => return '1';
      when others => return '0';
    end case;
  else
    case RtLenMode(3 downto 0) is
      when X\"0\" => return '1';
      when X\"2\" => return '1';
      when X\"3\" => return '1';
      when others => return '0';
    end case;
  end if;
end if;
else
 return '0';
end if;
end function;"
tm "LocalDeclTextMgr"
)
