oxt "0,0,15000,5000"
text (MLText
uid 4790,0
va (VaSet
fg "0,0,32768"
)
xt "-89800,-49800,-55500,-41800"
st "
TxDataAddr <= \"11111\" & RtLen_Mode when RtSubAddr = \"00000\" or RtSubAddr = \"11111\" else
                             RtSubAddr & std_logic_vector(to_unsigned(WordCount,5));
RxDataAddr <= \"11111\" & RtLen_Mode when RtSubAddr = \"00000\" or RtSubAddr = \"11111\" else
                      RtSubAddr & std_logic_vector(to_unsigned(WordCount,5));



or(RtAddr = \"11111\" and RtSubAddr /= \"00000\" and RtSubAddr /= \"11111\")
"
tm "CommentText"
wrapOption 3
visibleHeight 9000
visibleWidth 35000
)
)
