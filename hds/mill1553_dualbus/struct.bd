*113 (HdlText
uid 18885,0
optionalChildren [
*114 (EmbeddedText
uid 18891,0
commentText (CommentText
uid 18892,0
ps "CenterOffsetStrategy"
shape (Rectangle
uid 18893,0
va (VaSet
vasetType 1
fg "65535,65535,65535"
lineColor "0,0,32768"
lineWidth 2
)
xt "113000,146000,165000,165000"
)
oxt "0,0,18000,5000"
text (MLText
uid 18894,0
va (VaSet
)
xt "113200,146200,162400,162200"
st "
-- eb1 1         
RtAddrParityOK <=  MyRtAddrInt(4) xor MyRtAddrInt(3) xor MyRtAddrInt(2) xor MyRtAddrInt(1) xor MyRtAddrInt(0) xor MyRtAddrParityInt;
nResetBus1 <= '0' when (RtAddrParityOK = '0' or nResetCore1 = '0') else 
                        not BusSwapResetBus1 when IsRt = '1'  else 
                       nReset when (RtAddrParityOK = '1' and nResetCore1 = '1') else 
                         '0' when BusReset_Rxed1 = '1' or BusReset_Rxed2 = '1' else
                         '0';  
nResetBus2 <= '0' when (RtAddrParityOK = '0' or nResetCore2 = '0') else 
                        not BusSwapResetBus2 when IsRt = '1' else
                       nReset when (RtAddrParityOK = '1' and nResetCore2 = '1') else
                         '0' when BusReset_Rxed1 = '1' or BusReset_Rxed2 = '1' else
                         '0';  
nReset <= '0' when BusReset_Rxed1 = '1' or BusReset_Rxed2 = '1' else
                         nResetIn;  
StatusRxed1 <= StatusRxed1A(15 downto 8) & not RtAddrParityOK & StatusRxed1A(6 downto 0);
StatusRxed2 <= StatusRxed2A(15 downto 8) & not RtAddrParityOK & StatusRxed2A(6 downto 0);     
"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 19000
visibleWidth 52000
)
)
)
]
