st "
-- eGlue  
Instrumentation <= '0';
BrdcstRxed <= '0';
ClrParityErr <= '0';
ClrNoiseErr <= '0';
tmr_1us_Start <= '0';
tmr_1us_Stop <= '0';
nResetEnc <= '0' when SendMessage = '1' else
                           nReset when tmr_SAF = '0' else 
                           '1';
tmr_NRP_Start <= tmr_NRP_Start1 or CmdEdge or NewWord;
tmr_ERP_enable <= LastBitEdge;
tmr_ERP_Reset <= Encoder_ERP_Reset;
tmr_ERP_Stop <= '0';
reg_tmr_ERP <= X\"0190\";  --4.01us


                           
"
tm "HdlTextMgr"
wrapOption 3
visibleHeight 17000
visibleWidth 25000
)
)
)
