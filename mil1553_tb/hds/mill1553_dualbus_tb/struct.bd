*66 (HdlText
uid 2224,0
optionalChildren [
*67 (EmbeddedText
uid 2230,0
commentText (CommentText
uid 2231,0
ps "CenterOffsetStrategy"
shape (Rectangle
uid 2232,0
va (VaSet
